# ---------------------------------------------------------------------------
# Local development — copy to .env and fill in values. Never commit .env.
# ---------------------------------------------------------------------------

# Supabase Auth (safe to expose to browser)
# Get from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Gemini AI (server-side ONLY — never use NEXT_PUBLIC_ prefix)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Access control — only this email can sign in
ALLOWED_ACCESS_EMAILS=your-email@example.com
